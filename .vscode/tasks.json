{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Git: pull from origin (fast-forward only)",
      "type": "shell",
      "command": "git pull --ff-only",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
